# Dependencies
node_modules
.pnpm-store

# Build output (rebuilt in Docker)
.next
out

# Environment files (secrets — never copy into images)
.env
.env.*
!.env.example

# Documentation (not needed in prod image)
docs/
README.md
CHANGELOG.md

# Version control
.git
.gitignore

# Tests
**/*.test.*
**/*.spec.*
__tests__/
coverage/

# IDE / OS files
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker files (prevent recursive copy)
Dockerfile
.dockerignore
docker-compose*.yml
