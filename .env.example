# ──────────────────────────────────────────────────────────────────────
# News Triangulator — Environment Variables
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Authentication is handled by Google Cloud Application Default Credentials
# (ADC), NOT by a GEMINI_API_KEY. Run `gcloud auth application-default login`
# once and the app picks up your credentials automatically.
#
# See docs/ENV_SETUP.md for detailed instructions.
# ──────────────────────────────────────────────────────────────────────

# Optional: application URL (defaults to http://localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable the pre-flight "is this a news query?" validation call.
# Off by default to minimize Vertex AI quota usage.
# GEMINI_STORY_VALIDATION=true

# Optional: point at a service-account JSON file instead of using gcloud ADC.
# Leave unset on Cloud Run — the attached service account is used automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Set automatically by Next.js — no need to configure manually
# NODE_ENV=development
